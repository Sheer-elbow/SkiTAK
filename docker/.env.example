# SkiTAK Environment Configuration
# Copy this file to docker/.env and fill in all required values.
# NEVER commit .env to git.

# ── Server identity ───────────────────────────────────────────────────────
# The hostname or IP clients will use to reach this server. It is baked into
# enrollment packages (connectString). Use a domain name for production.
SERVER_HOSTNAME=skitak.yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────
# Avoid ':', '@' and '/' in the password — it is embedded in a database URL.
POSTGRES_DB=skitak
POSTGRES_USER=skitak
POSTGRES_PASSWORD=changeme_strong_password_here

# ── OpenTAKServer secrets ─────────────────────────────────────────────────
# Both are required and must stay stable — changing SECURITY_PASSWORD_SALT
# invalidates every stored password hash.
# Generate each with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_random_64char_hex_string
SECURITY_PASSWORD_SALT=changeme_generate_another_random_64char_hex_string

# ── Admin account ─────────────────────────────────────────────────────────
# OTS creates an `administrator` account with the password `password` on
# first boot. If this is set, the SkiTAK plugin replaces that default
# password at startup. Log in as: administrator / <this value>
SKITAK_ADMIN_PASSWORD=changeme_admin_password_here

# ── Mumble voice server (optional — `--profile voice`) ────────────────────
MUMBLE_SUPERUSER_PASSWORD=changeme_mumble_superuser_password

# ── Off-grid / Pi only (optional — `--profile mesh`) ──────────────────────
# Serial port for the Meshtastic LoRa radio (Pi compose only)
MESHTASTIC_PORT=/dev/ttyUSB0
