# SkiTAK Environment Configuration
# Copy this file to .env and fill in all required values
# NEVER commit .env to git

# ── Server identity ───────────────────────────────────────────────────────
# The hostname or IP clients will use to reach this server.
# Must match the TLS certificate CN. Use a domain name for production.
SERVER_HOSTNAME=skitak.yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DB=skitak
POSTGRES_USER=skitak
POSTGRES_PASSWORD=changeme_strong_password_here

# ── RabbitMQ ──────────────────────────────────────────────────────────────
RABBITMQ_USER=skitak
RABBITMQ_PASSWORD=changeme_rabbitmq_password_here

# ── OpenTAKServer ─────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
OTS_SECRET_KEY=changeme_generate_a_random_64char_hex_string

OTS_ADMIN_USER=admin
OTS_ADMIN_PASSWORD=changeme_admin_password_here

# ── Mumble voice server ───────────────────────────────────────────────────
MUMBLE_SUPERUSER_PASSWORD=changeme_mumble_superuser_password

# ── OS Maps ──────────────────────────────────────────────────────────────
# Get your key from https://osdatahub.os.uk — free tier available
# Key is injected into Nginx at container start and never sent to the browser
OS_MAPS_API_KEY=your_os_maps_api_key_here

# ── SSL / TLS ─────────────────────────────────────────────────────────────
# Set to "letsencrypt" for auto ACME certs (requires a public domain + port 80)
# Set to "selfsigned" for a self-signed cert (dev / private network)
# Set to "custom" to supply your own certs in docker/nginx/certs/
SSL_MODE=selfsigned

# ── Off-grid / Pi only ───────────────────────────────────────────────────
# Serial port for Meshtastic LoRa radio (Pi compose only)
MESHTASTIC_PORT=/dev/ttyUSB0
